#!/usr/bin/env python3

from __future__ import annotations

import json
import sys
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parent.parent
MARKETPLACE_PATH = REPO_ROOT / ".claude-plugin" / "marketplace.json"


def load_json(path: Path) -> dict:
    with path.open(encoding="utf-8") as handle:
        return json.load(handle)


def normalize_source(path_value: str) -> Path:
    return (REPO_ROOT / path_value).resolve()


def main() -> int:
    marketplace = load_json(MARKETPLACE_PATH)
    errors: list[str] = []

    plugins = marketplace.get("plugins")
    if not isinstance(plugins, list) or not plugins:
        errors.append(".claude-plugin/marketplace.json must define a non-empty plugins array")
        plugins = []

    root_name = marketplace.get("name")
    root_version = marketplace.get("metadata", {}).get("version")

    for index, plugin_entry in enumerate(plugins):
        if not isinstance(plugin_entry, dict):
            errors.append(f"plugins[{index}] must be an object")
            continue

        name = plugin_entry.get("name")
        version = plugin_entry.get("version")
        source = plugin_entry.get("source")

        if not name:
            errors.append(f"plugins[{index}] is missing name")
        if not version:
            errors.append(f"plugins[{index}] is missing version")
        if not source:
            errors.append(f"plugins[{index}] is missing source")
            continue

        source_path = normalize_source(source)
        try:
            source_path.relative_to(REPO_ROOT)
        except ValueError:
            errors.append(f"plugins[{index}].source escapes the repository root: {source}")
            continue

        plugin_manifest_path = source_path / ".claude-plugin" / "plugin.json"
        if not plugin_manifest_path.exists():
            errors.append(
                f"plugins[{index}].source does not contain .claude-plugin/plugin.json: {source}"
            )
            continue

        plugin_manifest = load_json(plugin_manifest_path)

        if plugin_manifest.get("name") != name:
            errors.append(
                f"{plugin_manifest_path.relative_to(REPO_ROOT)} name "
                f"{plugin_manifest.get('name')!r} does not match marketplace entry {name!r}"
            )

        if plugin_manifest.get("version") != version:
            errors.append(
                f"{plugin_manifest_path.relative_to(REPO_ROOT)} version "
                f"{plugin_manifest.get('version')!r} does not match marketplace entry {version!r}"
            )

        if len(plugins) == 1:
            if root_name != name:
                errors.append(
                    f".claude-plugin/marketplace.json name {root_name!r} does not match plugin name {name!r}"
                )
            if root_version != version:
                errors.append(
                    ".claude-plugin/marketplace.json metadata.version "
                    f"{root_version!r} does not match plugin version {version!r}"
                )

    if errors:
        print("plugin metadata validation failed:", file=sys.stderr)
        for error in errors:
            print(f"  - {error}", file=sys.stderr)
        return 1

    print(f"validated {len(plugins)} plugin metadata entr{'y' if len(plugins) == 1 else 'ies'}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
